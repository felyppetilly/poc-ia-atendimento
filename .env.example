# ============================================================
# .env.example — POC IA Atendimento (Lucas)
# Copie para `.env` e preencha. NÃO versione o `.env`.
# Em produção (Easypanel) as variáveis vão na tela Environment,
# não em um arquivo no servidor.
#
# Config incremental: nesta etapa só PORT/NODE_ENV são exigidas
# para bootar. Os segredos abaixo são opcionais por enquanto e
# viram obrigatórios nas stories que os consomem.
# ============================================================

# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- OpenAI (usado a partir da Story 1.4) ---
OPENAI_API_KEY=
# Opcional — default no config.ts é gpt-5.5
OPENAI_MODEL=

# --- Evolution API / WhatsApp (usado a partir da Story 1.3) ---
EVOLUTION_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
WEBHOOK_SECRET=

# --- Supabase (usado a partir da Story 1.2) ---
# SUPABASE_SERVICE_ROLE_KEY é server-only — NUNCA expor no frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Microsoft Graph (app-only — usado a partir da Story 2.1) ---
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=
LUCAS_USER_ID=

# --- Regras de negócio (têm default no config.ts) ---
LUCAS_WHATSAPP=+5511985303959
OFFICE_ADDRESS=Rua Maria Máximo 153, Ponta da Praia, Santos/SP
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=18
MAX_SLOTS=3
TIMEZONE=America/Sao_Paulo
